# Data + figures are regenerated artifacts; keep them out of git.
data/**
!data/.gitkeep
figures/**
!figures/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.env
.DS_Store
.idea/
.vscode/
.claude/

# run logs (regeneration helper output)
logs/**
!logs/.gitkeep
